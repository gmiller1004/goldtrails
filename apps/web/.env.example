# Copy to `.env.local` and fill in values (never commit `.env.local`).

# Public site URL (no trailing slash). Used for canonical URLs, sitemap, and JSON-LD.
# Example: https://goldtrails.gold
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Neon Postgres (masterclass reviews + certification enrollments + quiz attempts)
# Run db/migrations/001–003 once in Neon SQL Editor
DATABASE_URL=

# Klaviyo — masterclass download form (`/api/subscribe`)
# Private key only (Settings → API keys → Create Private API Key). Never use NEXT_PUBLIC_* for this.
# Scopes required now: profiles:write, lists:write, subscriptions:write, events:write
# Recommended for events tagging: tags:read, tags:write
KLAVIYO_API_KEY=
# List ID for "Gold Trails — Masterclass" (flow trigger: subscribed to this list)
KLAVIYO_LIST_ID=
# List ID for "Gold Trails — Events notify" (`/api/subscribe/events` on /events page)
# Flow trigger: subscribed to this list OR tagged `gold-trails-events-notify`
KLAVIYO_EVENTS_LIST_ID=
# List ID for "Gold Trails — Certification" (`/api/subscribe/certification` on /new-home)
# Flow trigger: subscribed to this list. Profile property `certification_token` powers quiz magic links.
KLAVIYO_CERTIFICATION_LIST_ID=
# List ID for "Gold Trails — Webinar waitlist" (`/api/subscribe/webinar` on `/#webinars`)
# Profile gets webinar_topic_of_interest + webinar_interest_* flags; tag `gt-webinar-waitlist`
KLAVIYO_GT_WEBINAR_LIST_ID=
# Optional: 6-character Company ID for future Klaviyo onsite JS — NOT used by /api/subscribe
# NEXT_PUBLIC_KLAVIYO_COMPANY_ID=

# Mailchimp (legacy fallback if KLAVIYO_API_KEY + KLAVIYO_LIST_ID are unset)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER=

# Shopify Storefront
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2025-01
# Certification reward kit (cert + hat). Claim uses Online Store cart permalink + discount.
# Claim route: /certification/claim?token=... (requires final quiz pass)
# Variant must be published to the Online Store sales channel.
CERTIFICATION_REWARD_PRODUCT_ID=10775411458358
CERTIFICATION_REWARD_VARIANT_ID=54217881256246
CERTIFICATION_REWARD_DISCOUNT_CODE=GTCertFinalPassed
# Optional. Defaults to gpaastore.com (primary storefront domain for cart permalinks).
SHOPIFY_CHECKOUT_DOMAIN=gpaastore.com

# Judge.me testimonials (events page)
JUDGEME_API_KEY=
# Optional. Defaults to SHOPIFY_STORE_DOMAIN if unset.
JUDGEME_SHOP_DOMAIN=

# SendGrid — contact form (`/api/contact`)
SENDGRID_API_KEY=
# Must be a verified sender in SendGrid
SENDGRID_FROM_EMAIL=
# Inbound destination for contact form (masterclass download lead SendGrid notifications are off)
SENDGRID_CONTACT_TO_EMAIL=
# Optional legacy alias — used only if SENDGRID_CONTACT_TO_EMAIL is unset
# CONTACT_TO_EMAIL=
